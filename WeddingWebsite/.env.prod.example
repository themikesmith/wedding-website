# Copy this file to .env.prod (do not commit .env.prod) and set real values.
# Used for production-style local runs, e.g.:
# docker compose --env-file .env.prod -f docker-compose.yml -f docker-compose.prod.yml up -d --build

# Required by docker-compose.prod.yml
DATABASE_URL=Host=<host>;Port=5432;Database=<database>;Username=<user>;Password=<password>;Ssl Mode=Require;Trust Server Certificate=true

# Optional app image tag if you later switch to registry-based image pulls
# IMAGE_TAG=latest
