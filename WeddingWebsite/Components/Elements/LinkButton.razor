@using WeddingWebsite.Models.ConfigInterfaces
@using WeddingWebsite.Models.Theme
@using WeddingWebsite.Models.WebsiteConfig
@using WeddingWebsite.Models.WebsiteElement

@inject IWebsiteConfig Config
@inject NavigationManager NavigationManager

<a class="@CssClass @VariantClass" href="@Url" style="@Css" target="@Target" rel="@Rel">
    @ChildContent
</a>

@if (Variant == ButtonVariant.Outlined)
{
    <style>
        .background-@Colour.GetHex().Substring(1):hover {
            background-color: @Colour;
        }
    </style>
}

@code {
  
    [Parameter]
    public required RenderFragment ChildContent { get; set; }
    
    [Parameter]
    public string? Url { get; set; }
    
    [Parameter]
    public string CssClass { get; set; } = "";
    
    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Filled;

    private string Css => Variant == ButtonVariant.Filled ? "background: " + Colour : $"border-color: {Colour}; color: {Colour}";
    private string VariantClass => Variant == ButtonVariant.Filled ? "filled" : $"outlined background-{Colour.GetHex().Substring(1)}";
    private bool IsExternal => IsExternalUrl(Url);
    private string? Target => IsExternal ? "_blank" : null;
    private string? Rel => IsExternal ? "noopener noreferrer" : null;
    
    [CascadingParameter]
    private SectionTheme? Theme { get; set; }
    
    private Colour Colour => Theme?.Primary ?? Config.Colours.Primary;

    private bool IsExternalUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return false;
        }

        if (url.StartsWith("/") || url.StartsWith("#"))
        {
            return false;
        }

        if (!Uri.TryCreate(url, UriKind.RelativeOrAbsolute, out var parsed))
        {
            return false;
        }

        if (!parsed.IsAbsoluteUri)
        {
            return false;
        }

        if (!Uri.TryCreate(NavigationManager.BaseUri, UriKind.Absolute, out var baseUri))
        {
            return true;
        }

        return !string.Equals(parsed.Host, baseUri.Host, StringComparison.OrdinalIgnoreCase);
    }
}