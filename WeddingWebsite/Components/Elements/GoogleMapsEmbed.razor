@using WeddingWebsite.Models.ConfigInterfaces
@using WeddingWebsite.Models.Events
@inject ICredentials Credentials
<iframe
    class="@ClassName"
    width="100%"
    height="@Height"
    style="border:0; width:100%; max-width:600px; height:@Height; display:block; margin-inline:auto;"
    loading="lazy"
    allowfullscreen
    referrerpolicy="no-referrer-when-downgrade"
    src="https://www.google.com/maps/embed/v1/place?key=@Credentials.GoogleMaps
    &q=@Location.Latitude,@Location.Longitude">
</iframe>

@code {
    [Parameter]
    public required Location Location { get; set; }
    
    [Parameter]
    public string Height { get; set; } = "450px";
    
    [Parameter]
    public string ClassName { get; set; } = "";
}